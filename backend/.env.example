# ─── Serveur ──────────────────────────────────────────────
PORT=5000

# URL(s) du frontend, séparées par des virgules si plusieurs
# (utilisée pour CORS et le lien dans l'email d'invitation)
# Exemple : FRONTEND_URL=http://localhost:5173,https://caisse-emergence.vercel.app


# FRONTEND_URL=http://localhost:5173

FRONTEND_URL=https://caisseemergence.vercel.app

# Nom de l'association affiché dans les emails
ASSOCIATION_NAME=La Caisse Emergence

# ─── Base de données MongoDB ─────────────────────────────────
# URI de connexion à votre cluster MongoDB Atlas (ou instance locale).
# ⚠️ Ne jamais commiter la vraie valeur : ce fichier est un exemple public.
MONGODB_URI=mongodb://127.0.0.1:27017/caisse_emergence

# ─── Authentification (JWT) ──────────────────────────────────
# Remplacez par une longue chaîne aléatoire (ex: générée avec
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=supersecretjwtkeychangeit
JWT_EXPIRES_IN=7d

# ─── Envoi d'emails (Brevo) ───────────────────────────────────
# Créez un compte gratuit sur https://brevo.com, vérifiez votre adresse
# d'envoi dans Senders, Domains & Dedicated IPs > Senders, puis récupérez
# votre clé API sur https://app.brevo.com/settings/keys/api (palier
# gratuit : 300 emails/jour, suffisant pour cette application).
# ⚠️ Sur Render (ou tout hébergeur sans IP fixe), désactivez la
# restriction "Authorise IPs" sous https://app.brevo.com/security/authorised_ips
# sinon Brevo bloquera les appels API venant d'une IP non reconnue
# (le SMTP n'est volontairement pas utilisé : Render bloque/timeout
# les ports SMTP sortants sur le plan gratuit).
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM="La Caisse Emergence <votre-adresse-verifiee@example.com>"

# ─── Compte secrétaire initial (créé par `npm run seed`) ─────
SECRETARY_NAME=Secrétaire
SECRETARY_EMAIL=secretaire@caisse-emergence.local
SECRETARY_PASSWORD=ChangezMoi123!

# ─── Tâche planifiée externe (anniversaires) ─────────────────
# Secret partagé attendu dans l'en-tête X-Cron-Secret par
# POST /api/members/birthdays/notify, appelée une fois par jour par le
# workflow GitHub Actions .github/workflows/birthday-reminder.yml
# (l'hébergement Render gratuit n'a pas de cron interne). Générez une
# longue valeur aléatoire et reportez-la aussi dans le secret GitHub
# CRON_SECRET du dépôt.
CRON_SECRET=changez-moi-en-valeur-aleatoire
