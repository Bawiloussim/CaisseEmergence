# ─── Serveur ──────────────────────────────────────────────
PORT=5000

# URL du frontend (utilisée dans le lien de l'email d'invitation et pour CORS)
FRONTEND_URL=http://localhost:5173

# Nom de l'association affiché dans les emails
ASSOCIATION_NAME=La Caisse Emergence

# ─── Base de données MongoDB (locale) ────────────────────────
# Si MongoDB est installé en local avec les réglages par défaut,
# cette valeur fonctionne directement.
MONGODB_URI=mongodb://127.0.0.1:27017/caisse_emergence

# ─── Authentification (JWT) ──────────────────────────────────
# Remplacez par une longue chaîne aléatoire (ex: générée avec
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=changez_moi_avec_une_longue_chaine_aleatoire
JWT_EXPIRES_IN=7d

# ─── Envoi d'emails (SMTP) ────────────────────────────────────
# Exemple avec Gmail : créez un "mot de passe d'application" sur
# https://myaccount.google.com/apppasswords (nécessite la validation
# en 2 étapes activée sur le compte Google).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre.email@gmail.com
SMTP_PASS=votre_mot_de_passe_application
EMAIL_FROM="La Caisse Emergence <votre.email@gmail.com>"

# ─── Compte secrétaire initial (créé par `npm run seed`) ─────
SECRETARY_NAME=Secrétaire
SECRETARY_EMAIL=secretaire@caisse-emergence.local
SECRETARY_PASSWORD=ChangezMoi123!
