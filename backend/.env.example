# ─── Serveur ──────────────────────────────────────────────
PORT=5000

# URL(s) du frontend, séparées par des virgules si plusieurs
# (utilisée pour CORS et le lien dans l'email d'invitation)
# Exemple : FRONTEND_URL=http://localhost:5173,https://caisse-emergence.vercel.app


# FRONTEND_URL=http://localhost:5173

FRONTEND_URL=https://caisseemergence.vercel.app

# Nom de l'association affiché dans les emails
ASSOCIATION_NAME=La Caisse Emergence

# ─── Base de données MongoDB ─────────────────────────────────
# URI de connexion à votre cluster MongoDB Atlas (ou instance locale).
# ⚠️ Ne jamais commiter la vraie valeur : ce fichier est un exemple public.
MONGODB_URI=mongodb://127.0.0.1:27017/caisse_emergence

# ─── Authentification (JWT) ──────────────────────────────────
# Remplacez par une longue chaîne aléatoire (ex: générée avec
# `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=supersecretjwtkeychangeit
JWT_EXPIRES_IN=7d

# ─── Envoi d'emails (SMTP) ─────────────────────────────────────
# Exemple avec Brevo (https://app.brevo.com/settings/keys/smtp, onglet
# SMTP — palier gratuit : 300 emails/jour) :
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
# Exemple avec Gmail (nécessite un mot de passe d'application, généré
# sur https://myaccount.google.com/apppasswords, pas votre mot de
# passe Gmail habituel) :
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre-login-smtp
SMTP_PASS=votre-cle-ou-mot-de-passe-smtp
EMAIL_FROM="La Caisse Emergence <votre-adresse-verifiee@example.com>"

# ─── Compte secrétaire initial (créé par `npm run seed`) ─────
SECRETARY_NAME=Secrétaire
SECRETARY_EMAIL=secretaire@caisse-emergence.local
SECRETARY_PASSWORD=ChangezMoi123!
